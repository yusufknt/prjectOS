{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProjectOS",
  "version": "1.0.0",
  "identifier": "com.projectos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProjectOS — Kişisel Proje ve Geliştirme Yönetimi",
        "width": 1360,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
